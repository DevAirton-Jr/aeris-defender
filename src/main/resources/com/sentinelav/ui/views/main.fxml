<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>

<BorderPane fx:id="mainPane" prefHeight="768.0" prefWidth="1024.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sentinelav.ui.controllers.MainController">
   <left>
      <VBox spacing="5.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <VBox spacing="2.0">
               <children>
                   <Label styleClass="sidebar-title-logo" text="Sentinel" />
                   <Label styleClass="sidebar-version" text="v2.5.0-Stable" />
               </children>
               <VBox.margin>
                  <Insets bottom="30.0" left="20.0" />
               </VBox.margin>
            </VBox>
            
            <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#showDashboard" prefWidth="260.0" styleClass="nav-button" text="Dashboard" />
            <Button fx:id="btnScanner" mnemonicParsing="false" onAction="#showScanner" prefWidth="260.0" styleClass="nav-button" text="Varredura" />
            <Button fx:id="btnQuarantine" mnemonicParsing="false" onAction="#showQuarantine" prefWidth="260.0" styleClass="nav-button" text="Quarantine" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button mnemonicParsing="false" onAction="#showScanner" prefWidth="220.0" styleClass="nav-full-scan" text="FULL SCAN">
               <VBox.margin>
                  <Insets bottom="20.0" left="20.0" right="20.0" />
               </VBox.margin>
            </Button>
            
            <Button fx:id="btnSettings" mnemonicParsing="false" onAction="#showSettings" prefWidth="260.0" styleClass="nav-button" text="⚙ Settings" />
            <Button mnemonicParsing="false" prefWidth="260.0" styleClass="nav-button" text="Support" />
         </children>
         <padding>
            <Insets bottom="20.0" top="30.0" />
         </padding>
      </VBox>
   </left>
</BorderPane>
