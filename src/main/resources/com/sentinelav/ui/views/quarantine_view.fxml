<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sentinelav.ui.controllers.QuarantineController">
   <children>
      <Label text="Cofre de Quarentena" styleClass="title-label"/>
      <TableView fx:id="quarantineTable" prefHeight="400.0" prefWidth="600.0">
        <columns>
          <TableColumn fx:id="nameColumn" prefWidth="450.0" text="Nome do Arquivo Suspeito" />
          <TableColumn fx:id="sizeColumn" minWidth="0.0" prefWidth="150.0" text="Tamanho" />
        </columns>
      </TableView>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#refreshList" styleClass="nav-button" text="Atualizar Lista" />
            <Button mnemonicParsing="false" onAction="#deleteSelected" styleClass="nav-button" style="-fx-background-color: #f44336;" text="Excluir Permanentemente" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
